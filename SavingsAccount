package qn1_accounts;

public class SavingsAccount extends Account {
    // Private attribute matching the '-' symbol
    private double rate;

    // Subclass constructor chaining up to the parent class super-constructor
    public SavingsAccount(String accountNo, double opening, double rate) {
        super(accountNo, opening);
        this.rate = rate;
    }

    @Override
    public boolean withdraw(double amount) {
        // Business Rule: Ensure balance does not drop below zero (no negative balance)
        if (this.balance - amount >= 0) {
            this.balance -= amount;
            return true; // Withdrawal approved
        }
        return false; // Withdrawal denied due to insufficient funds
    }

    // Adds rate percentage of the current balance back to the balance field
    public void addInterest() {
        this.balance += (this.balance * (this.rate / 100.0));
    }
}
